<% content_for :title, "お問い合わせ | KIMEAL" %>

<main class="mx-auto max-w-4xl px-4 py-10">
  <section class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100">
    <p class="text-sm font-semibold text-orange-700">Contact</p>
    <h1 class="mt-2 text-2xl font-bold text-stone-950">お問い合わせ</h1>
    <p class="mt-3 text-sm leading-6 text-stone-600">
      KIMEALに関するお問い合わせ、不具合報告、ご要望は、GitHub Issueよりご連絡ください。
    </p>

    <div class="mt-6 rounded-lg bg-orange-50 p-5">
      <h2 class="text-base font-bold text-stone-950">お問い合わせ先</h2>
      <p class="mt-2 text-sm text-stone-700">GitHubリポジトリのIssueからお問い合わせください。</p>
      <%= link_to "GitHub Issueを開く", "https://github.com/RyuYamaguchi080312/KIMEAL/issues", target: "_blank", rel: "noopener", class: "mt-4 inline-flex rounded-lg bg-orange-500 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-orange-600" %>
    </div>
  </section>
</main>
