<article
  class="mx-auto mt-3 max-w-md overflow-hidden rounded-xl border border-orange-100 bg-orange-50/40 shadow-sm select-none will-change-transform [touch-action:pan-y]<%= " hidden" if local_assigns[:hidden] %>"
  data-swipe-card-target="card"
  data-recipe-id="<%= recipe.id %>"
  data-action="pointerdown->swipe-card#start pointermove->swipe-card#move pointerup->swipe-card#end pointercancel->swipe-card#reset"
>
  <% if recipe.image.attached? %>
    <%= image_tag recipe.image, alt: recipe.title, class: "h-56 w-full object-cover" %>
  <% elsif recipe.image_url.present? %>
    <%= image_tag recipe.image_url, alt: recipe.title, class: "h-56 w-full object-cover" %>
  <% else %>
    <div class="flex h-56 items-center justify-center bg-orange-100 text-sm font-semibold text-orange-700">
      No Image
    </div>
  <% end %>

  <div class="p-5">
    <h2 class="text-xl font-semibold text-stone-950"><%= recipe.title %></h2>
    <p class="mt-2 text-sm text-stone-600"><%= recipe.category.name %></p>

    <div class="mt-3 flex flex-wrap gap-2">
      <% if recipe.tags.any? %>
        <% recipe.tags.each do |tag| %>
          <span class="rounded-full bg-white px-2.5 py-1 text-xs font-medium text-orange-700 ring-1 ring-orange-100"><%= tag.name %></span>
        <% end %>
      <% else %>
        <span class="rounded-full bg-white px-2.5 py-1 text-xs font-medium text-stone-500 ring-1 ring-orange-100">タグ未設定</span>
      <% end %>
    </div>

    <% if recipe.description.present? %>
      <p class="mt-3 line-clamp-3 text-sm text-stone-600"><%= recipe.description %></p>
    <% end %>

    <div class="mt-4 flex flex-wrap gap-2">
      <%= link_to "詳細を見る", recipe_path(recipe), class: "rounded-md border border-orange-200 px-3 py-2 text-sm font-semibold text-orange-700 hover:bg-orange-50" %>
      <%= button_to "今日の一品に決定", select_swipes_path, params: { recipe_id: recipe.id }, class: "rounded-md bg-orange-500 px-3 py-2 text-sm font-semibold text-white hover:bg-orange-600" %>
    </div>
  </div>
</article>
