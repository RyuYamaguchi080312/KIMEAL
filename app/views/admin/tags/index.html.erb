<main class="mx-auto max-w-5xl px-4 py-10">
  <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
    <section class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100" aria-labelledby="tag-form-title">
      <h1 id="tag-form-title" class="text-2xl font-bold text-stone-950">タグ管理</h1>
      <p class="mt-3 text-sm text-stone-600">レシピの条件や気分に使うタグを追加できます。</p>

      <%= form_with model: [:admin, @tag], class: "mt-6 space-y-5" do |f| %>
        <% if @tag.errors.any? %>
          <div id="error_explanation">
            <h2>入力内容を確認してください</h2>
            <ul>
              <% @tag.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "タグ名", class: "block text-sm font-medium text-stone-700" %>
          <%= f.text_field :name, class: ["mt-1 w-full rounded-md border px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2", @tag.errors[:name].any? ? "is-invalid border-red-500 focus:ring-red-100" : "border-orange-200 focus:border-orange-400 focus:ring-orange-100"] %>
          <% @tag.errors[:name].each do |message| %>
            <p class="field-error">タグ名<%= message %></p>
          <% end %>
        </div>

        <%= f.submit "追加", class: "w-full rounded-lg bg-orange-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-orange-600" %>
      <% end %>
    </section>

    <section class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100" aria-labelledby="tag-list-title">
      <h2 id="tag-list-title" class="text-xl font-bold text-stone-950">タグ一覧</h2>

      <% if @tags.any? %>
        <ul class="mt-6 space-y-4">
          <% @tags.each do |tag| %>
            <li class="rounded-lg border border-orange-100 bg-orange-50/40 p-4">
              <%= form_with model: [:admin, tag], class: "grid gap-3 sm:grid-cols-[1fr_auto_auto]" do |f| %>
                <div>
                  <%= f.label :name, "タグ名", class: "sr-only" %>
                  <%= f.text_field :name, class: ["w-full rounded-md border px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2", tag.errors[:name].any? ? "is-invalid border-red-500 focus:ring-red-100" : "border-orange-200 bg-white focus:border-orange-400 focus:ring-orange-100"] %>
                  <% tag.errors[:name].each do |message| %>
                    <p class="field-error">タグ名<%= message %></p>
                  <% end %>
                  <p class="mt-1 text-xs text-stone-500">作成日時: <%= l(tag.created_at, format: :short) %></p>
                </div>

                <%= f.submit "更新", class: "rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600" %>
              <% end %>

              <div class="mt-3 flex justify-end">
                <%= button_to "削除", admin_tag_path(tag), method: :delete, form: { data: { turbo_confirm: "タグ「#{tag.name}」を削除しますか？" } }, class: "rounded-md border border-red-200 px-4 py-2 text-sm font-semibold text-red-600 hover:bg-red-50" %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-6 rounded-lg bg-orange-50 p-4 text-sm text-stone-600">タグはまだ登録されていません。</p>
      <% end %>
    </section>
  </div>
</main>
