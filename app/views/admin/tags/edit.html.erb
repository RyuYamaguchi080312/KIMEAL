<main class="mx-auto max-w-2xl px-4 py-10">
  <section class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100" aria-labelledby="tag-edit-title">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 id="tag-edit-title" class="text-2xl font-bold text-stone-950">タグ編集</h1>
        <p class="mt-3 text-sm text-stone-600">タグ名を更新できます。</p>
      </div>
      <%= link_to "一覧へ戻る", admin_tags_path, class: "rounded-md border border-orange-200 px-4 py-2 text-sm font-semibold text-orange-700 hover:bg-orange-50" %>
    </div>

    <%= form_with model: [:admin, @tag], class: "mt-6 space-y-5" do |f| %>
      <% if @tag.errors.any? %>
        <div id="error_explanation">
          <h2>入力内容を確認してください</h2>
          <ul>
            <% @tag.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "タグ名", class: "block text-sm font-medium text-stone-700" %>
        <%= f.text_field :name, class: ["mt-1 w-full rounded-md border px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2", @tag.errors[:name].any? ? "is-invalid border-red-500 focus:ring-red-100" : "border-orange-200 focus:border-orange-400 focus:ring-orange-100"] %>
        <% @tag.errors[:name].each do |message| %>
          <p class="field-error">タグ名<%= message %></p>
        <% end %>
      </div>

      <%= f.submit "更新", class: "w-full rounded-lg bg-orange-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-orange-600" %>
    <% end %>
  </section>
</main>
