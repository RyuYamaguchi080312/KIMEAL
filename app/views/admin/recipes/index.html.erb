<main class="mx-auto max-w-5xl px-4 py-10">
  <section class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100" aria-labelledby="recipe-admin-title">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h1 id="recipe-admin-title" class="text-2xl font-bold text-stone-950">レシピ管理</h1>
        <p class="mt-3 text-sm text-stone-600">登録済みレシピの確認と、登録・編集・削除の導線を管理します。</p>
      </div>

      <%= link_to "レシピを登録", new_admin_recipe_path, class: "rounded-lg bg-orange-500 px-5 py-3 text-center text-sm font-semibold text-white shadow-sm hover:bg-orange-600" %>
    </div>

    <% if @recipes.any? %>
      <div class="mt-6 overflow-hidden rounded-lg border border-orange-100">
        <div class="hidden bg-orange-50 px-4 py-3 text-xs font-semibold text-stone-600 sm:grid sm:grid-cols-[1.5fr_0.8fr_0.9fr_0.7fr_0.8fr] sm:gap-4">
          <span>レシピ名</span>
          <span>カテゴリ</span>
          <span>タグ</span>
          <span>調理時間</span>
          <span class="text-right">操作</span>
        </div>

        <ul class="divide-y divide-orange-100">
          <% @recipes.each do |recipe| %>
            <li class="grid gap-3 px-4 py-4 sm:grid-cols-[1.5fr_0.8fr_0.9fr_0.7fr_0.8fr] sm:items-center sm:gap-4">
              <div class="flex items-center gap-3">
                <% if recipe.image.attached? %>
                  <%= image_tag recipe.image, alt: recipe.title, class: "size-16 rounded-md object-cover" %>
                <% end %>
                <div>
                  <p class="font-semibold text-stone-900"><%= recipe.title %></p>
                  <p class="mt-1 text-xs text-stone-500">作成日時: <%= l(recipe.created_at, format: :short) %></p>
                </div>
              </div>

              <p class="text-sm text-stone-700"><%= recipe.category.name %></p>

              <p class="text-sm text-stone-700">
                <%= recipe.tags.any? ? recipe.tags.map(&:name).join("、") : "未設定" %>
              </p>

              <p class="text-sm text-stone-700">
                <%= recipe.cooking_time.present? ? "#{recipe.cooking_time}分" : "未設定" %>
              </p>

              <div class="flex gap-2 sm:justify-end">
                <%= link_to "#", aria: { label: "編集" }, class: "inline-flex size-10 items-center justify-center rounded-md bg-orange-500 text-white hover:bg-orange-600" do %>
                  <svg aria-hidden="true" class="size-5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="m13.498 3.59 2.912 2.912a2.125 2.125 0 0 1 0 3.005l-6.86 6.86a2.75 2.75 0 0 1-1.351.728l-3.048.677a.75.75 0 0 1-.894-.894l.677-3.048a2.75 2.75 0 0 1 .728-1.35l6.86-6.86a2.125 2.125 0 0 1 3.005 0ZM12.438 4.65l-5.716 5.716 2.912 2.912 5.716-5.716a.625.625 0 0 0 0-.884l-2.028-2.028a.625.625 0 0 0-.884 0ZM5.97 13.423a1.25 1.25 0 0 0-.331.614l-.373 1.678 1.678-.373a1.25 1.25 0 0 0 .614-.331l.989-.989-2.588-2.588-.989.989Z" />
                  </svg>
                <% end %>
                <%= button_tag type: :button, aria: { label: "削除" }, class: "inline-flex size-10 items-center justify-center rounded-md border border-red-200 text-red-600 hover:bg-red-50" do %>
                  <svg aria-hidden="true" class="size-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8.75 1.75A2.25 2.25 0 0 0 6.5 4v.25H3.75a.75.75 0 0 0 0 1.5h.3l.76 10.28a2.25 2.25 0 0 0 2.244 2.084h5.892a2.25 2.25 0 0 0 2.244-2.084l.76-10.28h.3a.75.75 0 0 0 0-1.5H13.5V4a2.25 2.25 0 0 0-2.25-2.25h-2.5ZM8 4a.75.75 0 0 1 .75-.75h2.5A.75.75 0 0 1 12 4v.25H8V4Zm.25 4.75a.75.75 0 0 0-1.5 0v5.5a.75.75 0 0 0 1.5 0v-5.5Zm5 0a.75.75 0 0 0-1.5 0v5.5a.75.75 0 0 0 1.5 0v-5.5Z" clip-rule="evenodd" />
                  </svg>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% else %>
      <p class="mt-6 rounded-lg bg-orange-50 p-4 text-sm text-stone-600">レシピはまだ登録されていません。</p>
    <% end %>
  </section>
</main>
