<main class="mx-auto max-w-5xl px-4 py-10">
  <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
    <section class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100" aria-labelledby="category-form-title">
      <h1 id="category-form-title" class="text-2xl font-bold text-stone-950">カテゴリ管理</h1>
      <p class="mt-3 text-sm text-stone-600">レシピ分類に使うカテゴリを追加できます。</p>

      <%= form_with model: [:admin, @category], class: "mt-6 space-y-5" do |f| %>
        <% if @category.errors.any? %>
          <div id="error_explanation">
            <h2>入力内容を確認してください</h2>
            <ul>
              <% @category.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "カテゴリ名", class: "block text-sm font-medium text-stone-700" %>
          <%= f.text_field :name, class: ["mt-1 w-full rounded-md border px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2", @category.errors[:name].any? ? "is-invalid border-red-500 focus:ring-red-100" : "border-orange-200 focus:border-orange-400 focus:ring-orange-100"] %>
          <% @category.errors[:name].each do |message| %>
            <p class="field-error">カテゴリ名<%= message %></p>
          <% end %>
        </div>

        <%= f.submit "追加", class: "w-full rounded-lg bg-orange-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-orange-600" %>
      <% end %>
    </section>

    <section class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100" aria-labelledby="category-list-title">
      <h2 id="category-list-title" class="text-xl font-bold text-stone-950">カテゴリ一覧</h2>

      <% if @categories.any? %>
        <ul class="mt-6 divide-y divide-orange-100">
          <% @categories.each do |category| %>
            <li class="flex items-center justify-between py-3">
              <span class="font-medium text-stone-800"><%= category.name %></span>
              <span class="text-xs text-stone-500"><%= l(category.created_at, format: :short) %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-6 rounded-lg bg-orange-50 p-4 text-sm text-stone-600">カテゴリはまだ登録されていません。</p>
      <% end %>
    </section>
  </div>
</main>
