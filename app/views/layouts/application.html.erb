<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "KIMEAL" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# PWA対応を進める場合は、routes.rbと合わせて有効化する %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :tailwind, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-orange-50 text-stone-900">
    <% top_page = controller_path == "top" %>

    <header class="<%= top_page ? "absolute inset-x-0 top-0 z-20 bg-black/35 text-white backdrop-blur-sm" : "border-b border-orange-100 bg-white/95" %>">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
        <%= link_to user_signed_in? ? home_path : root_path, class: "flex items-center gap-3 text-lg font-bold tracking-wide #{top_page ? "text-white" : "text-stone-900"}" do %>
          <%= image_tag "kimeal_icon.png", alt: "", class: "h-10 w-10 shrink-0 object-contain" %>
          <span>KIMEAL <span class="font-normal opacity-80">| キミール</span></span>
        <% end %>

        <% if user_signed_in? %>
          <div class="flex items-center gap-4">
            <span class="text-sm <%= top_page ? "text-white/85" : "text-stone-600" %>"><%= current_user.name.presence || current_user.email %> さん</span>
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "rounded-md border px-3 py-1.5 text-sm font-medium #{top_page ? "border-white/60 text-white hover:bg-white/10" : "border-orange-200 text-stone-700 hover:bg-orange-50"}" %>
          </div>
        <% else %>
          <div class="flex items-center gap-3">
            <%= link_to "ログイン", new_user_session_path, class: "text-sm font-medium #{top_page ? "text-white hover:text-orange-100" : "text-stone-700 hover:text-orange-600"}" %>
            <%= link_to "新規登録", new_user_registration_path, class: "rounded-md px-3 py-1.5 text-sm font-medium #{top_page ? "bg-white text-orange-600 hover:bg-orange-50" : "bg-orange-500 text-white hover:bg-orange-600"}" %>
          </div>
        <% end %>
      </nav>
    </header>

    <div class="<%= top_page ? "absolute inset-x-0 top-20 z-30 mx-auto max-w-5xl px-4" : "mx-auto max-w-5xl px-4" %>">
      <% flash.each do |type, message| %>
        <div class="flash flash-<%= type %> <%= top_page ? "shadow-lg" : "mt-4" %>" role="alert">
          <%= message %>
        </div>
      <% end %>
    </div>

    <%= yield %>
  </body>
</html>
