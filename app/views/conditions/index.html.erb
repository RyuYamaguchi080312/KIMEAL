<main class="mx-auto max-w-4xl px-4 py-10">
  <section class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100" aria-labelledby="conditions-title">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h1 id="conditions-title" class="text-2xl font-bold text-stone-950">条件を選択</h1>
        <p class="mt-3 text-sm text-stone-600">食べたいカテゴリや気分に合うタグを選んで、レシピ候補を探しましょう。</p>
      </div>

      <%= link_to "ホームへ戻る", home_path, class: "rounded-lg border border-orange-200 px-4 py-2 text-center text-sm font-semibold text-orange-700 hover:bg-orange-50" %>
    </div>

    <%= form_with url: swipes_path, method: :get, class: "mt-8 space-y-8" do |f| %>
      <div data-controller="category-filter">
        <%= f.label :category_id, "カテゴリ", class: "block text-sm font-medium text-stone-700" %>
        <div class="mt-2 grid gap-2 sm:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
          <div>
            <%= label_tag :category_keyword, "カテゴリ検索", class: "sr-only" %>
            <%= search_field_tag :category_keyword, nil, placeholder: "カテゴリ名で検索", class: "w-full rounded-md border border-orange-200 px-3 py-2 text-sm shadow-sm focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-100", data: { category_filter_target: "query", action: "input->category-filter#filter" } %>
          </div>
          <%= f.collection_select :category_id, @categories, :id, :name, { include_blank: "指定しない" }, class: "w-full rounded-md border border-orange-200 px-3 py-2 text-sm shadow-sm focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-100", data: { category_filter_target: "select" } %>
        </div>
        <p class="mt-1 text-xs text-stone-500">表示カテゴリ: <span data-category-filter-target="count"><%= @categories.size %>件</span></p>
      </div>

      <fieldset data-controller="checkbox-filter">
        <legend class="text-sm font-medium text-stone-700">タグ</legend>

        <% if @tags.any? %>
          <div class="mt-3">
            <%= label_tag :tag_keyword, "タグ検索", class: "sr-only" %>
            <%= search_field_tag :tag_keyword, nil, placeholder: "タグ名で検索", class: "w-full rounded-md border border-orange-200 px-3 py-2 text-sm shadow-sm focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-100", data: { checkbox_filter_target: "query", action: "input->checkbox-filter#filter" } %>
            <p class="mt-1 text-xs text-stone-500">表示タグ: <span data-checkbox-filter-target="count"><%= @tags.size %>件</span></p>
          </div>

          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            <% @tags.each do |tag| %>
              <label class="flex items-center gap-3 rounded-lg border border-orange-100 bg-orange-50/40 px-4 py-3 text-sm text-stone-700" data-checkbox-filter-target="item" data-filter-text="<%= tag.name %>">
                <%= check_box_tag "tag_ids[]", tag.id, false, id: "tag_ids_#{tag.id}", class: "size-4 rounded border-orange-300 text-orange-500 focus:ring-orange-200" %>
                <span><%= tag.name %></span>
              </label>
            <% end %>
          </div>
        <% else %>
          <p class="mt-3 rounded-lg bg-orange-50 p-4 text-sm text-stone-600">タグはまだ登録されていません。</p>
        <% end %>
      </fieldset>

      <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
        <%= link_to "キャンセル", home_path, class: "rounded-lg border border-orange-200 px-5 py-3 text-center text-sm font-semibold text-orange-700 hover:bg-orange-50" %>
        <%= f.submit "この条件で探す", class: "rounded-lg bg-orange-500 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-orange-600" %>
      </div>
    <% end %>
  </section>
</main>
