<main class="mx-auto max-w-5xl px-4 py-10">
  <div class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-stone-950">レシピ一覧</h1>
        <p class="mt-3 text-sm text-stone-600">登録済みのレシピを確認できます。</p>
      </div>
      <%= link_to "ホームへ戻る", home_path, class: "rounded-lg border border-orange-200 px-4 py-2 text-center text-sm font-semibold text-orange-700 hover:bg-orange-50" %>
    </div>

    <%= form_with url: recipes_path, method: :get, class: "mt-6 grid gap-3 sm:grid-cols-[1fr_auto] sm:items-center", data: { controller: "category-filter" } do |f| %>
      <div>
        <%= f.label :category_id, "楽天カテゴリから取得", class: "block text-sm font-medium text-stone-700" %>
        <div class="mt-1 grid gap-2 sm:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
          <div>
            <%= label_tag :category_keyword, "カテゴリ検索", class: "sr-only" %>
            <%= search_field_tag :category_keyword, nil, placeholder: "カテゴリ名で検索", class: "w-full rounded-md border border-orange-200 px-3 py-2 text-sm shadow-sm focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-100", data: { category_filter_target: "query", action: "input->category-filter#filter" } %>
          </div>
          <%= f.collection_select :category_id, @categories, :id, :name, { include_blank: "カテゴリを選択", selected: @selected_category&.id }, class: "w-full rounded-md border border-orange-200 px-3 py-2 text-sm shadow-sm focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-100", data: { category_filter_target: "select" } %>
        </div>
        <p class="mt-1 text-xs text-stone-500">表示カテゴリ: <span data-category-filter-target="count"><%= @categories.size %>件</span></p>
      </div>
      <div>
        <%= f.submit "レシピを取得", class: "w-full rounded-lg bg-orange-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-orange-600" %>
      </div>
    <% end %>

    <% if @rakuten_recipe_error.present? %>
      <p class="mt-4 rounded-lg bg-red-50 p-4 text-sm text-red-600"><%= @rakuten_recipe_error %></p>
    <% end %>

    <% if @recipes.any? %>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% @recipes.each do |recipe| %>
          <article class="overflow-hidden rounded-lg border border-orange-100 bg-orange-50/40">
            <% if recipe.image.attached? %>
              <%= image_tag recipe.image, alt: recipe.title, class: "h-40 w-full object-cover" %>
            <% elsif recipe.image_url.present? %>
              <%= image_tag recipe.image_url, alt: recipe.title, class: "h-40 w-full object-cover" %>
            <% else %>
              <div class="flex h-40 items-center justify-center bg-orange-100 text-sm font-semibold text-orange-700">
                No Image
              </div>
            <% end %>

            <div class="p-4">
              <h2 class="font-semibold text-stone-950"><%= recipe.title %></h2>
              <p class="mt-2 text-sm text-stone-600"><%= recipe.category.name %></p>

              <div class="mt-3 flex flex-wrap gap-2">
                <% if recipe.tags.any? %>
                  <% recipe.tags.each do |tag| %>
                    <span class="rounded-full bg-white px-2.5 py-1 text-xs font-medium text-orange-700 ring-1 ring-orange-100"><%= tag.name %></span>
                  <% end %>
                <% else %>
                  <span class="rounded-full bg-white px-2.5 py-1 text-xs font-medium text-stone-500 ring-1 ring-orange-100">タグ未設定</span>
                <% end %>
              </div>

              <% if recipe.description.present? %>
                <p class="mt-3 line-clamp-3 text-sm text-stone-600"><%= recipe.description %></p>
              <% end %>

              <%= link_to "詳細を見る", recipe_path(recipe), class: "mt-4 inline-flex text-sm font-semibold text-orange-700 hover:text-orange-900" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="mt-6 rounded-lg bg-orange-50 p-4 text-sm text-stone-600">表示できるレシピがありません。</p>
    <% end %>
  </div>
</main>
