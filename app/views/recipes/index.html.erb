<main class="mx-auto max-w-5xl px-4 py-10">
  <div class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100">
    <h1 class="text-2xl font-bold text-stone-950">レシピ一覧</h1>
    <p class="mt-3 text-sm text-stone-600">カテゴリを選択すると、楽天レシピAPIからランキングレシピを取得します。</p>

    <%= form_with url: recipes_path, method: :get, class: "mt-6 grid gap-3 sm:grid-cols-[1fr_auto]" do |f| %>
      <div>
        <%= f.label :category_id, "カテゴリ", class: "block text-sm font-medium text-stone-700" %>
        <%= f.collection_select :category_id, @categories, :id, :name, { include_blank: "カテゴリを選択", selected: @selected_category&.id }, class: "mt-1 w-full rounded-md border border-orange-200 px-3 py-2 text-sm shadow-sm focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-100" %>
      </div>
      <div class="flex items-end">
        <%= f.submit "レシピを取得", class: "w-full rounded-lg bg-orange-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-orange-600" %>
      </div>
    <% end %>

    <% if @rakuten_recipe_error.present? %>
      <p class="mt-4 rounded-lg bg-red-50 p-4 text-sm text-red-600"><%= @rakuten_recipe_error %></p>
    <% end %>

    <% if @recipes.any? %>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% @recipes.each do |recipe| %>
          <article class="overflow-hidden rounded-lg border border-orange-100 bg-orange-50/40">
            <% if recipe.image_url.present? %>
              <%= image_tag recipe.image_url, alt: recipe.title, class: "h-36 w-full object-cover" %>
            <% end %>
            <div class="p-4">
              <h2 class="font-semibold text-stone-950"><%= recipe.title %></h2>
              <p class="mt-2 text-sm text-stone-600"><%= recipe.category.name %></p>
              <% if recipe.description.present? %>
                <p class="mt-2 line-clamp-3 text-sm text-stone-600"><%= recipe.description %></p>
              <% end %>
              <% if recipe.source_url.present? %>
                <%= link_to "楽天レシピで見る", recipe.source_url, target: "_blank", rel: "noopener", class: "mt-3 inline-flex text-sm font-semibold text-orange-700 hover:text-orange-900" %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="mt-6 rounded-lg bg-orange-50 p-4 text-sm text-stone-600">表示できるレシピがありません。</p>
    <% end %>
  </div>
</main>
