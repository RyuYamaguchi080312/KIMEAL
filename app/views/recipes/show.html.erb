<main class="mx-auto max-w-4xl px-4 py-10">
  <article class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-sm font-semibold text-orange-700"><%= @recipe.category.name %></p>
        <h1 class="mt-2 text-2xl font-bold text-stone-950"><%= @recipe.title %></h1>

        <div class="mt-3 flex flex-wrap gap-2">
          <% if @recipe.tags.any? %>
            <% @recipe.tags.each do |tag| %>
              <span class="rounded-full bg-orange-50 px-3 py-1 text-xs font-medium text-orange-700 ring-1 ring-orange-100"><%= tag.name %></span>
            <% end %>
          <% else %>
            <span class="rounded-full bg-stone-50 px-3 py-1 text-xs font-medium text-stone-500 ring-1 ring-stone-100">タグ未設定</span>
          <% end %>
        </div>
      </div>

      <%= link_to "一覧へ戻る", recipes_path, class: "rounded-lg border border-orange-200 px-4 py-2 text-center text-sm font-semibold text-orange-700 hover:bg-orange-50" %>
    </div>

    <div class="mt-6 overflow-hidden rounded-lg bg-orange-50">
      <% if @recipe.image.attached? %>
        <%= image_tag @recipe.image, alt: @recipe.title, class: "h-72 w-full object-cover" %>
      <% elsif @recipe.image_url.present? %>
        <%= image_tag @recipe.image_url, alt: @recipe.title, class: "h-72 w-full object-cover" %>
      <% else %>
        <div class="flex h-72 items-center justify-center bg-orange-100 text-sm font-semibold text-orange-700">
          No Image
        </div>
      <% end %>
    </div>

    <% if @recipe.description.present? || @recipe.cooking_time.present? %>
      <section class="mt-6 rounded-lg bg-orange-50 p-4">
        <% if @recipe.description.present? %>
          <p class="text-sm leading-6 text-stone-700"><%= @recipe.description %></p>
        <% end %>

        <% if @recipe.cooking_time.present? %>
          <p class="mt-3 text-sm font-semibold text-stone-700">調理時間: <%= @recipe.cooking_time %>分</p>
        <% end %>
      </section>
    <% end %>

    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <section>
        <h2 class="text-lg font-bold text-stone-950">材料</h2>
        <% if @recipe.ingredients.present? %>
          <div class="mt-3 whitespace-pre-wrap rounded-lg border border-orange-100 p-4 text-sm leading-6 text-stone-700"><%= @recipe.ingredients %></div>
        <% else %>
          <p class="mt-3 rounded-lg bg-orange-50 p-4 text-sm text-stone-600">材料は未登録です。</p>
        <% end %>
      </section>

      <section>
        <h2 class="text-lg font-bold text-stone-950">作り方</h2>
        <% if @recipe.instructions.present? %>
          <div class="mt-3 whitespace-pre-wrap rounded-lg border border-orange-100 p-4 text-sm leading-6 text-stone-700"><%= @recipe.instructions %></div>
        <% elsif @recipe.source_url.present? %>
          <div class="mt-3 rounded-lg bg-orange-50 p-4 text-sm leading-6 text-stone-700">
            <p>作り方は楽天レシピで確認できます。</p>
            <%= link_to "楽天レシピで作り方を見る", @recipe.source_url, target: "_blank", rel: "noopener", class: "mt-3 inline-flex font-semibold text-orange-700 hover:text-orange-900" %>
          </div>
        <% else %>
          <p class="mt-3 rounded-lg bg-orange-50 p-4 text-sm text-stone-600">作り方は未登録です。</p>
        <% end %>
      </section>
    </div>
  </article>
</main>
