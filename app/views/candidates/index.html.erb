<main class="mx-auto max-w-5xl px-4 py-10">
  <section class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100" aria-labelledby="candidates-title">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h1 id="candidates-title" class="text-2xl font-bold text-stone-950">候補一覧</h1>
        <p class="mt-3 text-sm text-stone-600">食べたいにしたレシピから、今日の一品を決めましょう。</p>
      </div>

      <%= link_to "レシピを探す", swipes_path, class: "rounded-lg border border-orange-200 px-4 py-2 text-center text-sm font-semibold text-orange-700 hover:bg-orange-50" %>
    </div>

    <% if @daily_selection.present? %>
      <section class="mt-6 rounded-lg bg-orange-50 p-4" aria-labelledby="daily-selection-title">
        <h2 id="daily-selection-title" class="text-sm font-semibold text-stone-900">今日の一品</h2>
        <p class="mt-2 text-lg font-bold text-stone-950"><%= @daily_selection.recipe.title %></p>
      </section>
    <% end %>

    <% if @liked_swipes.any? %>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% @liked_swipes.each do |swipe| %>
          <% recipe = swipe.recipe %>
          <article class="overflow-hidden rounded-lg border border-orange-100 bg-orange-50/40">
            <% if recipe.image.attached? %>
              <%= image_tag recipe.image, alt: recipe.title, class: "h-40 w-full object-cover" %>
            <% elsif recipe.image_url.present? %>
              <%= image_tag recipe.image_url, alt: recipe.title, class: "h-40 w-full object-cover" %>
            <% else %>
              <div class="flex h-40 items-center justify-center bg-orange-100 text-sm font-semibold text-orange-700">
                No Image
              </div>
            <% end %>

            <div class="p-4">
              <h2 class="font-semibold text-stone-950"><%= recipe.title %></h2>
              <p class="mt-2 text-sm text-stone-600"><%= recipe.category.name %></p>

              <div class="mt-3 flex flex-wrap gap-2">
                <% if recipe.tags.any? %>
                  <% recipe.tags.each do |tag| %>
                    <span class="rounded-full bg-white px-2.5 py-1 text-xs font-medium text-orange-700 ring-1 ring-orange-100"><%= tag.name %></span>
                  <% end %>
                <% else %>
                  <span class="rounded-full bg-white px-2.5 py-1 text-xs font-medium text-stone-500 ring-1 ring-orange-100">タグ未設定</span>
                <% end %>
              </div>

              <div class="mt-4 flex flex-wrap gap-2">
                <%= link_to "詳細を見る", recipe_path(recipe), class: "rounded-md border border-orange-200 px-3 py-2 text-sm font-semibold text-orange-700 hover:bg-orange-50" %>
                <%= button_to "候補から削除", candidate_path(swipe), method: :delete, class: "rounded-md border border-red-200 px-3 py-2 text-sm font-semibold text-red-600 hover:bg-red-50" %>
                <%= button_to "今日の一品に決定", select_candidate_path(swipe), method: :post, class: "rounded-md bg-orange-500 px-3 py-2 text-sm font-semibold text-white hover:bg-orange-600" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="mt-6 rounded-lg bg-orange-50 p-4 text-sm text-stone-600">食べたい候補はまだありません。</p>
    <% end %>
  </section>
</main>
