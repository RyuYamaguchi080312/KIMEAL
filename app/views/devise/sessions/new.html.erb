<main class="mx-auto max-w-md px-4 py-10">
  <div class="rounded-xl bg-white p-8 shadow-sm ring-1 ring-orange-100">
    <h1 class="text-2xl font-bold text-stone-950">ログイン</h1>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-stone-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 w-full rounded-md border border-orange-200 px-3 py-2 text-sm shadow-sm focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-100" %>
      </div>

      <div>
        <%= f.label :password, "パスワード", class: "block text-sm font-medium text-stone-700" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "mt-1 w-full rounded-md border border-orange-200 px-3 py-2 text-sm shadow-sm focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-100" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "rounded border-orange-200 text-orange-500" %>
          <%= f.label :remember_me, "ログイン状態を保持する", class: "text-sm text-stone-600" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "ログイン", class: "w-full rounded-lg bg-orange-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-orange-600" %>
      </div>
    <% end %>

    <p class="mt-6 text-center text-sm text-stone-600">
      アカウントがない方は
      <%= link_to "新規登録", new_user_registration_path, class: "font-semibold text-orange-600 underline underline-offset-4" %>
    </p>
  </div>
</main>
